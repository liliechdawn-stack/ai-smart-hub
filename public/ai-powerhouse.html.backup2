                <i class="fas fa-magic"></i> Generate with AI
            </button>
        </div>
        
        <div id="contentImagesTab" style="display: none;">
            <div class="form-group">
                <label>Image Prompt</label>
                <textarea id="imagePrompt" class="form-control" rows="3" placeholder="Describe the image you want to generate..."></textarea>
            </div>
            
            <div class="form-group">
                <label>Style</label>
                <select id="imageStyle" class="form-control">
                    <option value="realistic">Realistic</option>
                    <option value="cartoon">Cartoon</option>
                    <option value="anime">Anime</option>
                    <option value="oil-painting">Oil Painting</option>
                    <option value="watercolor">Watercolor</option>
                    <option value="3d-render">3D Render</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>Aspect Ratio</label>
                <select id="imageRatio" class="form-control">
                    <option value="1:1">Square (1:1) - Instagram</option>
                    <option value="16:9">Landscape (16:9) - YouTube</option>
                    <option value="9:16">Portrait (9:16) - TikTok/Reels</option>
                    <option value="4:5">Portrait (4:5) - Instagram Feed</option>
                </select>
            </div>
            
            <button class="btn-primary" onclick="generateImage()" style="width: 100%; padding: 14px;">
                <i class="fas fa-image"></i> Generate Image
            </button>
            
            <div id="imagePreview" style="margin-top: 20px; display: none;">
                <img src="" alt="Generated Image" style="width: 100%; border-radius: 8px;">
            </div>
        </div>
        
        <div id="contentVideoTab" style="display: none;">
            <div class="form-group">
                <label>Video Topic</label>
