async function connectAccount() {
    if (!selectedPlatform) {
        showToast('Please select a platform', 'error');
        return;
    }
    
    const accountName = document.getElementById('accountName').value;
    const method = document.getElementById('connectionMethod').value;
    
    if (!accountName) {
        showToast('Please enter account name', 'error');
        return;
    }
    
    const platform = platforms.find(p => p.id === selectedPlatform);
    
    let connectionData = {
        platform: selectedPlatform,
        accountName: accountName,
        method: method
    };
    
    if (method === 'gateway') {
        const cfAccountId = document.getElementById('cfAccountId').value;
        const gatewayName = document.getElementById('gatewayName').value;
        const cfToken = document.getElementById('cfToken').value;
        
        if (!cfAccountId || !gatewayName || !cfToken) {
            showToast('Please fill all gateway fields', 'error');
            return;
        }
        
        connectionData = {
            ...connectionData,
            gatewayConfig: {
                accountId: cfAccountId,
                gatewayName: gatewayName,
                apiToken: cfToken
            }
        };
        
        const gatewayUrl = `${CLOUDFLARE_GATEWAY_URL}/${cfAccountId}/${gatewayName}`;
        connectionData.gatewayUrl = gatewayUrl;
        
    } else {
        const apiKey = document.getElementById('apiKey').value;
        if (!apiKey) {
            showToast('Please enter API key', 'error');
            return;
        }
        connectionData.apiKey = apiKey;
        
        const additionalFields = {};
        document.querySelectorAll('#additionalFields input').forEach(input => {
            additionalFields[input.id] = input.value;
        });
        connectionData.additionalFields = additionalFields;
    }
    
    const connectBtn = event.target;
    const originalText = connectBtn.innerHTML;
    connectBtn.innerHTML = '<div class="loading-spinner"></div> Connecting...';
    connectBtn.disabled = true;
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/connect`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(connectionData)
        });
        
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        if (response.ok) {
            const result = await response.json();
            if (method === 'gateway') {
                showToast('✅ Connected via Cloudflare Gateway! Unified access to 400+ models', 'success');
            } else {
                showToast('✅ Account connected successfully!', 'success');
            }
            closeModal();
            await loadConnectedAccounts();
            await loadActivityLog();
            
            // NEW: Auto-activate features for this platform
            await autoActivateFeaturesForAccount({ platform: selectedPlatform, id: result.account.id });
        } else {
            const error = await response.json();
            showToast(error.error || 'Failed to connect account', 'error');
        }
    } catch (error) {
        showToast('Connection service unavailable', 'error');
    } finally {
        connectBtn.innerHTML = originalText;
        connectBtn.disabled = false;
    }
}

// Make all functions globally available
window.filterFeatures = filterFeatures;
