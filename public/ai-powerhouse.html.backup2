// ===== TOGGLE FEATURE LIVE STATUS =====
function toggleFeatureLive(featureId) {
    const featureCard = document.getElementById(featureId);
    if (!featureCard) return;
    
    if (featureCard.classList.contains('live')) {
        featureCard.classList.remove('live');
        featureCard.classList.add('paused');
        
        const featureName = featureCard.querySelector('h3')?.textContent || 'Feature';
        removeActiveFeature(featureId);
        
        showToast(`⏸️ ${featureName} paused`, 'info');
    } else {
        featureCard.classList.remove('paused');
        featureCard.classList.add('live');
        
        const featureName = featureCard.querySelector('h3')?.textContent || 'Feature';
        addActiveFeature({
            id: featureId,
            name: featureName
        });
        
        showToast(`✅ ${featureName} activated`, 'success');
        
        if (socket && socket.connected) {
            socket.emit('feature_toggle', { id: featureId, status: 'active' });
        }
    }
}

// ===== CONTENT CREATOR SPECIFIC FUNCTIONS =====
async function generateHashtags() {
    showToast('🔍 Generating hashtags...', 'info');
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/hashtags/generate`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ topic: 'AI automation' })
        });
        
        if (response.ok) {
            const data = await response.json();
            showToast(data.hashtags, 'success');
        } else {
            showToast('#AI #Automation #ContentCreator #SocialMedia #Marketing #Growth', 'success');
        }
    } catch (error) {
        showToast('#AI #Automation #ContentCreator #SocialMedia #Marketing #Growth', 'success');
    }
}

