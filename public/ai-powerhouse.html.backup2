                    <span>Best time to post: <strong>Tomorrow 3:00 PM</strong> (based on your audience)</span>
                </div>
            </div>
            
            <button class="btn-primary" onclick="scheduleContent()" style="width: 100%; padding: 14px;">
                <i class="fas fa-calendar-check"></i> Schedule Post
            </button>
        </div>
    </div>
</div>

<script>
// ================================================
// AI POWERHOUSE 2.0 - ULTIMATE AUTOMATION PLATFORM
// 500+ Integrations - 47 Live Features - Real-Time Status
// ================================================

const BACKEND_URL = window.BACKEND_URL || 'https://ai-smart-hub.onrender.com';
const API_BASE = `${BACKEND_URL}/api`;
console.log('🚀 AI Powerhouse 2.0 Ultimate - Starting...');
console.log('API Base URL:', API_BASE);

const CLOUDFLARE_GATEWAY_URL = 'https://gateway.ai.cloudflare.com/v1';
const ADMIN_EMAIL = "ericchung992@gmail.com";

// WebSocket for real-time updates
let socket = null;

// Global state
let activeAgents = 0;
let imagesProcessed = 0;
let totalLeads = 0;
let hoursSaved = 0;
let performanceChart;
let selectedPlatform = null;
let userData = {};
let userPlan = 'free';
let automationStats = {};
let connectedAccounts = [];
let recentActivity = [];
let userAutomations = [];

// Track active features
let activeFeatures = [];

// Automation scheduler
let automationScheduler = null;

// Feature-platform mapping for auto-activation
const FEATURE_PLATFORM_MAP = {
    'feature-video': ['youtube', 'tiktok', 'instagram'],
    'feature-hashtag': ['instagram', 'tiktok', 'twitter'],
    'feature-inventory': ['shopify', 'woocommerce', 'amazon'],
    'feature-cart': ['shopify', 'woocommerce'],
    'feature-price': ['shopify', 'amazon', 'ebay'],
    'feature-content-pro': ['instagram', 'tiktok', 'facebook', 'twitter'],
    'feature-social': ['instagram', 'tiktok', 'youtube', 'facebook'],
    'feature-engagement': ['instagram', 'tiktok', 'youtube', 'twitter'],
    'feature-image': ['youtube', 'tiktok', 'instagram'],
    'feature-lead': ['salesforce', 'hubspot', 'zoho']
};

// Automation schedules
const AUTOMATION_SCHEDULES = {
    'feature-video': { frequency: 'daily', time: '09:00', timezone: 'auto' },
    'feature-hashtag': { frequency: 'daily', time: '10:00' },
    'feature-inventory': { frequency: 'hourly', realtime: true },
    'feature-price': { frequency: 'daily', time: '02:00' },
    'feature-cart': { frequency: 'realtime', checkInterval: 15 },
    'feature-engagement': { frequency: 'hourly' },
    'feature-content-pro': { frequency: 'daily', time: '08:00' },
    'feature-social': { frequency: 'continuous', checkInterval: 5 }
};

// COMPLETE PLATFORM DATA - 500+ Platforms (Abbreviated for performance, full list in backend)
const platforms = [
    // Social Media
    { id: 'tiktok', name: 'TikTok', icon: 'fab fa-tiktok', color: '#010101', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'instagram', name: 'Instagram', icon: 'fab fa-instagram', color: '#d62976', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'youtube', name: 'YouTube', icon: 'fab fa-youtube', color: '#ff0000', category: 'video', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'facebook', name: 'Facebook', icon: 'fab fa-facebook', color: '#4267B2', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'twitter', name: 'X (Twitter)', icon: 'fab fa-twitter', color: '#1da1f2', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'linkedin', name: 'LinkedIn', icon: 'fab fa-linkedin', color: '#0077b5', category: 'professional', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'pinterest', name: 'Pinterest', icon: 'fab fa-pinterest', color: '#E60023', category: 'visual', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'snapchat', name: 'Snapchat', icon: 'fab fa-snapchat', color: '#FFFC00', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'reddit', name: 'Reddit', icon: 'fab fa-reddit', color: '#FF4500', category: 'forum', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'twitch', name: 'Twitch', icon: 'fab fa-twitch', color: '#9146FF', category: 'streaming', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    
    // Chinese Platforms
    { id: 'douyin', name: 'Douyin', icon: 'fas fa-music', color: '#000000', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'wechat', name: 'WeChat', icon: 'fab fa-weixin', color: '#07c160', category: 'chat', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'weibo', name: 'Weibo', icon: 'fab fa-weibo', color: '#E6162D', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'xiaohongshu', name: 'Xiaohongshu', icon: 'fas fa-heart', color: '#FF5A5F', category: 'social', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'bilibili', name: 'Bilibili', icon: 'fas fa-play', color: '#FB7299', category: 'video', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    
    // E-commerce
    { id: 'shopify', name: 'Shopify', icon: 'fab fa-shopify', color: '#7AB55C', category: 'ecommerce', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'woocommerce', name: 'WooCommerce', icon: 'fab fa-wordpress', color: '#96588A', category: 'ecommerce', type: 'api-wrapper', governance: 'basic', multiAgent: false },
    { id: 'amazon', name: 'Amazon Seller', icon: 'fab fa-amazon', color: '#FF9900', category: 'ecommerce', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'ebay', name: 'eBay', icon: 'fab fa-ebay', color: '#E53238', category: 'ecommerce', type: 'saas', governance: 'medium', multiAgent: false },
    
    // Enterprise SaaS
    { id: 'salesforce', name: 'Salesforce', icon: 'fab fa-salesforce', color: '#00A1E0', category: 'crm', type: 'saas', governance: 'full', multiAgent: true },
    { id: 'hubspot', name: 'HubSpot', icon: 'fab fa-hubspot', color: '#FF7A59', category: 'crm', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'servicenow', name: 'ServiceNow', icon: 'fas fa-cloud', color: '#00B0B9', category: 'enterprise', type: 'saas', governance: 'full', multiAgent: true },
    
    // Payment & Finance
    { id: 'stripe', name: 'Stripe', icon: 'fab fa-stripe', color: '#635BFF', category: 'finance', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'paypal', name: 'PayPal', icon: 'fab fa-paypal', color: '#00457C', category: 'finance', type: 'saas', governance: 'medium', multiAgent: false },
    
    // Communication
    { id: 'slack', name: 'Slack', icon: 'fab fa-slack', color: '#4A154B', category: 'communication', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'discord', name: 'Discord', icon: 'fab fa-discord', color: '#5865F2', category: 'communication', type: 'saas', governance: 'medium', multiAgent: false },
    
    // Project Management
    { id: 'asana', name: 'Asana', icon: 'fas fa-asana', color: '#F06A6A', category: 'project', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'trello', name: 'Trello', icon: 'fab fa-trello', color: '#0079BF', category: 'project', type: 'saas', governance: 'medium', multiAgent: false },
    { id: 'jira', name: 'Jira', icon: 'fab fa-jira', color: '#0052CC', category: 'project', type: 'saas', governance: 'medium', multiAgent: false },
    
    // Gateway
    { id: 'cloudflare', name: 'Cloudflare AI Gateway', icon: 'fas fa-cloud', color: '#F38020', category: 'gateway', type: 'gateway', governance: 'high', multiAgent: true }
];

// ===== TOKEN HELPERS =====
function getPlanFromToken() {
    try {
        const token = localStorage.getItem('token');
        if (!token) return null;
        const parts = token.split('.');
        if (parts.length !== 3) return null;
        return JSON.parse(atob(parts[1]));
    } catch (e) {
        return null;
    }
}

// ===== CHECK ACCESS =====
async function checkAccess() {
    try {
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = 'login.html';
            return false;
        }

        const payload = getPlanFromToken();
        if (payload) {
            userPlan = (payload.plan || 'free').toLowerCase();
            if (payload.email === ADMIN_EMAIL) return true;
            if (userPlan === 'pro' || userPlan === 'agency') return true;
        }

        const response = await fetch(`${BACKEND_URL}/api/dashboard/full`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });

        if (!response.ok) throw new Error('Failed to fetch plan');

        const data = await response.json();
        userPlan = (data.plan || 'free').toLowerCase();
        
        if (userPlan === 'pro' || userPlan === 'agency' || data.email === ADMIN_EMAIL) {
            return true;
        }
        return false;
    } catch (err) {
        console.error("[ACCESS CHECK ERROR]", err);
        return false;
    }
}

// ===== WEBSOCKET CONNECTION =====
function initWebSocket() {
    try {
        const token = localStorage.getItem('token');
        socket = io(BACKEND_URL, {
            transports: ['websocket'],
            query: { token }
        });
        
        socket.on('connect', () => {
            console.log('🔌 WebSocket connected - Real-time updates active');
            document.getElementById('liveIndicator').innerHTML = '🔴 Live';
        });
        
        socket.on('stats_update', (data) => {
            console.log('📊 Stats update received', data);
            if (data.activeAgents !== undefined) {
                activeAgents = data.activeAgents;
                updateStats();
            }
        });
        
        socket.on('activity', (activity) => {
            console.log('📋 New activity:', activity);
            recentActivity.unshift(activity);
            if (recentActivity.length > 10) recentActivity.pop();
            loadActivityLog();
        });
        
        socket.on('alert', (alert) => {
            console.log('⚠️ New alert:', alert);
            showToast(alert.message, 'warning');
            addAlertToObservability(alert);
        });
        
        socket.on('feature_activated', (feature) => {
            console.log('✅ Feature activated:', feature);
            addActiveFeature(feature);
        });
        
        socket.on('feature_deactivated', (featureId) => {
            console.log('⏸️ Feature deactivated:', featureId);
            removeActiveFeature(featureId);
        });
        
        socket.on('disconnect', () => {
            console.log('🔌 WebSocket disconnected');
            document.getElementById('liveIndicator').innerHTML = '⭕ Offline';
        });
    } catch (error) {
        console.warn('WebSocket not available, using polling');
    }
}

// ===== START AUTOMATION SCHEDULER (NEW) =====
function startAutomationScheduler() {
    console.log('⏰ Starting automation scheduler...');
    
    // Check every minute for scheduled tasks
    automationScheduler = setInterval(async () => {
        const now = new Date();
        const currentHour = now.getHours();
        const currentMinute = now.getMinutes();
        const currentTime = `${currentHour.toString().padStart(2, '0')}:${currentMinute.toString().padStart(2, '0')}`;
        
        // Check each connected account for scheduled automations
        for (const account of connectedAccounts) {
            for (const [featureId, platforms] of Object.entries(FEATURE_PLATFORM_MAP)) {
                if (!platforms.includes(account.platform)) continue;
                
                const schedule = AUTOMATION_SCHEDULES[featureId];
                if (!schedule) continue;
                
                // Check if feature is active
                const featureCard = document.getElementById(featureId);
                if (!featureCard || !featureCard.classList.contains('live')) continue;
                
                // Check if this feature should run now
                let shouldRun = false;
                
                if (schedule.frequency === 'realtime') {
                    shouldRun = true;
                } else if (schedule.frequency === 'hourly') {
                    shouldRun = currentMinute === 0;
                } else if (schedule.frequency === 'daily' && schedule.time === currentTime) {
                    shouldRun = true;
                }
                
                if (shouldRun) {
                    executeScheduledAutomation(account, featureId);
                }
            }
        }
    }, 60000); // Check every minute
}

// ===== EXECUTE SCHEDULED AUTOMATION (NEW) =====
async function executeScheduledAutomation(account, featureId) {
    console.log(`🤖 Running scheduled automation: ${featureId} for ${account.platform}`);
    
    try {
        const token = localStorage.getItem('token');
        let response;
        
        switch(featureId) {
            case 'feature-video':
                response = await fetch(`${API_BASE}/powerhouse/video/script/auto`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        platform: account.platform,
                        autoGenerate: true,
                        count: 3
                    })
                });
                break;
                
            case 'feature-hashtag':
                response = await fetch(`${API_BASE}/powerhouse/hashtags/auto`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        platform: account.platform,
                        trending: true,
                        count: 10
                    })
                });
                break;
                
            case 'feature-inventory':
                response = await fetch(`${API_BASE}/powerhouse/inventory/auto-check`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        platform: account.platform,
                        alertLowStock: true,
                        autoReorder: true
                    })
                });
                break;
                
            case 'feature-cart':
                response = await fetch(`${API_BASE}/powerhouse/carts/auto-recover`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        platform: account.platform,
                        hoursOld: 24,
                        autoSendDiscount: true
                    })
                });
                break;
                
            default:
                return;
        }
        
        if (response && response.ok) {
            const data = await response.json();
            
            // Log the automation run
            addNotification('🤖 Automation Complete', 
                `${featureId} ran successfully for ${account.platform}`);
            
            // Update stats
            await loadStats();
            await loadActivityLog();
        }
        
    } catch (error) {
        console.error(`Automation failed for ${featureId}:`, error);
    }
}

// ===== AUTO-ACTIVATE FEATURES WHEN ACCOUNT CONNECTED (NEW) =====
async function autoActivateFeaturesForAccount(account) {
    console.log(`🤖 Auto-activating features for ${account.platform}...`);
    
    const activated = [];
    
    for (const [featureId, platforms] of Object.entries(FEATURE_PLATFORM_MAP)) {
        if (platforms.includes(account.platform)) {
            const featureCard = document.getElementById(featureId);
            if (featureCard && !featureCard.classList.contains('live')) {
                featureCard.classList.add('live');
                featureCard.classList.remove('paused');
                
                const featureName = featureCard.querySelector('h3')?.textContent || featureId;
                addActiveFeature({
                    id: featureId,
                    name: featureName,
                    platform: account.platform
                });
                
                activated.push(featureName);
                
                // Log activation
                logAutoActivation(account.platform, featureName);
            }
        }
    }
    
    if (activated.length > 0) {
        showToast(`✨ Auto-activated ${activated.length} features for ${account.platform}!`, 'success');
    }
    
    return activated;
}

// ===== LOG AUTO-ACTIVATION (NEW) =====
function logAutoActivation(platform, feature) {
    const logEntry = {
        id: Date.now(),
        title: `✨ Auto-activated: ${feature}`,
        message: `Feature automatically enabled for ${platform}`,
        time: 'Just now',
        icon: 'fa-robot',
        color: '#10B981',
        type: 'automation'
    };
    
    recentActivity.unshift(logEntry);
    if (recentActivity.length > 10) recentActivity.pop();
    loadActivityLog();
}

// ===== GET AI RECOMMENDATIONS (NEW) =====
async function getAIRecommendations() {
    if (connectedAccounts.length === 0) return;
    
    const recommendations = [];
    
    for (const account of connectedAccounts) {
        const accountAge = daysSince(account.created_at);
        
        // Recommend features based on account age
        if (accountAge < 7) {
            recommendations.push({
                platform: account.platform,
                feature: 'AI Content Studio',
                reason: 'New account detected - start with daily posts to build audience',
                priority: 'high',
                action: 'content'
            });
        }
        
        // Check for missing features
        const activeFeatureIds = activeFeatures.map(f => f.id);
        
        for (const [featureId, platforms] of Object.entries(FEATURE_PLATFORM_MAP)) {
            if (!platforms.includes(account.platform)) continue;
            
            const featureCard = document.getElementById(featureId);
            const featureName = featureCard?.querySelector('h3')?.textContent || featureId;
            
            if (!activeFeatureIds.includes(featureId)) {
                recommendations.push({
                    platform: account.platform,
                    feature: featureName,
                    reason: `This feature works great with ${account.platform} and could boost your results`,
                    priority: 'medium',
                    action: 'activate'
                });
            }
        }
    }
    
    return recommendations.slice(0, 3); // Show top 3 recommendations
}

// ===== RENDER AI RECOMMENDATIONS (NEW) =====
async function renderRecommendations() {
    const section = document.getElementById('recommendationsSection');
    const grid = document.getElementById('recommendationsGrid');
    
    const recommendations = await getAIRecommendations();
    
    if (!recommendations || recommendations.length === 0) {
        section.style.display = 'none';
        return;
    }
    
    section.style.display = 'block';
    grid.innerHTML = recommendations.map(rec => `
        <div class="recommendation-item">
            <div class="recommendation-icon">
                <i class="fas fa-robot"></i>
            </div>
            <div class="recommendation-content">
                <div class="recommendation-title">
                    Activate ${rec.feature} for ${rec.platform}
                </div>
                <div class="recommendation-desc">
                    ${rec.reason}
                </div>
            </div>
            <div>
                <span class="recommendation-priority priority-${rec.priority}">
                    ${rec.priority.toUpperCase()}
                </span>
            </div>
            <button class="btn-primary" style="padding: 8px 16px;" 
                    onclick="activateRecommendedFeature('${rec.feature}')">
                Activate
            </button>
        </div>
    `).join('');
}

// ===== ACTIVATE RECOMMENDED FEATURE (NEW) =====
function activateRecommendedFeature(featureName) {
    // Find the feature card by name
    const cards = document.querySelectorAll('.feature-card');
    for (const card of cards) {
        const title = card.querySelector('h3')?.textContent;
        if (title === featureName) {
            const toggleBtn = card.querySelector('.btn-outline:last-child');
            if (toggleBtn) {
                toggleBtn.click();
            }
            break;
        }
    }
}

// ===== DAYS SINCE HELPER (NEW) =====
function daysSince(dateString) {
    const then = new Date(dateString);
    const now = new Date();
    const diffTime = Math.abs(now - then);
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    return diffDays;
}

// ===== ACTIVE FEATURES MANAGEMENT =====
function addActiveFeature(feature) {
    if (!activeFeatures.find(f => f.id === feature.id)) {
        activeFeatures.push(feature);
        renderActiveFeatures();
        renderRecommendations(); // Update recommendations
    }
}

function removeActiveFeature(featureId) {
    activeFeatures = activeFeatures.filter(f => f.id !== featureId);
    renderActiveFeatures();
    renderRecommendations(); // Update recommendations
}

function renderActiveFeatures() {
    const section = document.getElementById('activeFeaturesSection');
    const grid = document.getElementById('activeFeaturesGrid');
    
    if (activeFeatures.length === 0) {
        section.style.display = 'none';
        return;
    }
    
    section.style.display = 'block';
    grid.innerHTML = activeFeatures.map(f => `
        <div class="active-feature-item">
            <i class="fas fa-check-circle"></i>
            <span class="feature-name">${f.name}</span>
            <span class="feature-status">LIVE</span>
        </div>
    `).join('');
}

// ===== INITIALIZATION =====
document.addEventListener('DOMContentLoaded', async function() {
    console.log('🚀 AI Powerhouse 2.0 Ultimate Edition Starting...');
    
    const hasAccess = await checkAccess();
    if (!hasAccess) {
        document.getElementById('accessDeniedOverlay').classList.add('active');
        return;
    }
    
    updateDate();
    await loadUserData();
    initCharts();
    await loadAllData();
    loadPlatformOptions();
    startLiveUpdates();
    initWebSocket();
    renderFeatures();
    startAutomationScheduler(); // Start the automation scheduler
});

// ===== LOAD ALL DATA =====
async function loadAllData() {
    try {
        document.getElementById('accountsGrid').innerHTML = '<div style="padding: 20px; text-align: center; width: 100%;"><div class="loading-spinner"></div> Loading accounts...</div>';
        document.getElementById('activityLog').innerHTML = '<div style="padding: 20px; text-align: center;"><div class="loading-spinner"></div> Loading activity...</div>';
        
        await Promise.all([
            loadStats(),
            loadConnectedAccounts(),
            loadActivityLog(),
            loadUserAutomations(),
            loadActiveFeatures()
        ]);
        
        // After accounts are loaded, get recommendations
        await renderRecommendations();
        
    } catch (error) {
        console.error('Error loading data:', error);
        showToast('⚠️ Failed to load some data. Please refresh.', 'error');
    }
}

// ===== LOAD ACTIVE FEATURES =====
async function loadActiveFeatures() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/automations?status=active`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
            const automations = await response.json();
            activeFeatures = automations.map(a => ({
                id: a.id,
                name: a.name
            }));
            renderActiveFeatures();
        }
    } catch (error) {
        console.error('Error loading active features:', error);
    }
}

// ===== LOAD USER AUTOMATIONS =====
async function loadUserAutomations() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/automations`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        if (response.ok) {
            userAutomations = await response.json();
            const live = userAutomations.filter(a => a.status === 'active').length;
            const paused = userAutomations.filter(a => a.status === 'paused').length;
            const today = userAutomations.filter(a => {
                const lastRun = new Date(a.last_run || 0);
                const today = new Date();
                return lastRun.toDateString() === today.toDateString();
            }).length;
            
            document.getElementById('liveCount').textContent = live;
            document.getElementById('pausedCount').textContent = paused;
            document.getElementById('totalRuns').textContent = today;
            
            // Calculate governance score
            const connectedTypes = connectedAccounts.map(a => {
                const platform = platforms.find(p => p.id === a.platform);
                return platform ? platform.type : 'api-wrapper';
            });
            
            const fullSaaS = connectedTypes.filter(t => t === 'saas').length;
            const gateways = connectedTypes.filter(t => t === 'gateway').length;
            const wrappers = connectedTypes.filter(t => t === 'api-wrapper').length;
            
            const total = connectedTypes.length || 1;
            const score = Math.round(((fullSaaS * 100) + (gateways * 80) + (wrappers * 30)) / total);
            document.getElementById('governanceScore').textContent = score + '%';
        }
    } catch (error) {
        console.error('Error loading automations:', error);
    }
}

// ===== LOAD STATS =====
async function loadStats() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/stats`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        if (response.ok) {
            const stats = await response.json();
            activeAgents = stats.activeAgents || 0;
            imagesProcessed = stats.imagesProcessed || 0;
            totalLeads = stats.totalLeads || 0;
            hoursSaved = stats.hoursSaved || 0;
            automationStats = stats;
        }
    } catch (error) {
        console.error('Error loading stats:', error);
    }
    
    updateStats();
}

// ===== LOAD USER DATA =====
async function loadUserData() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/user/profile`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        if (response.ok) {
            userData = await response.json();
            document.getElementById('userName').textContent = userData.business_name || userData.name || 'User';
        }
    } catch (error) {
        document.getElementById('userName').textContent = 'User';
    }
}

// ===== UPDATE DATE =====
function updateDate() {
    const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-US', options);
}

// ===== INIT CHARTS =====
function initCharts() {
    const ctx = document.getElementById('performanceChart')?.getContext('2d');
    if (!ctx) return;
    
    performanceChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
            datasets: [
                {
                    label: 'Views',
                    data: [12400, 18900, 23400, 27800, 31200, 35600, 38900],
                    borderColor: '#d4af37',
                    backgroundColor: 'rgba(212,175,55,0.1)',
                    borderWidth: 2,
                    pointRadius: 2,
                    tension: 0.3,
                    fill: true
                },
                {
                    label: 'Engagement',
                    data: [3200, 4800, 6200, 7100, 8300, 9400, 10200],
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37,99,235,0.1)',
                    borderWidth: 2,
                    pointRadius: 2,
                    tension: 0.3,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { 
                    beginAtZero: true, 
                    grid: { display: false }
                },
                x: { grid: { display: false } }
            }
        }
    });
}

// ===== UPDATE STATS =====
function updateStats() {
    document.getElementById('activeAgents').textContent = activeAgents.toLocaleString();
    document.getElementById('activeAgentsDisplay').textContent = activeAgents.toLocaleString();
    document.getElementById('imagesProcessed').textContent = imagesProcessed.toLocaleString();
    document.getElementById('totalLeads').textContent = totalLeads.toLocaleString();
    document.getElementById('hoursSaved').textContent = hoursSaved.toLocaleString();
}

// ===== LIVE UPDATES =====
function startLiveUpdates() {
    setInterval(async () => {
        try {
            const token = localStorage.getItem('token');
            const response = await fetch(`${API_BASE}/powerhouse/stats`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (response.status === 401) { 
                localStorage.removeItem('token'); 
                window.location.href = 'login.html'; 
                return; 
            } 
            if (response.ok) {
                const stats = await response.json();
                activeAgents = stats.activeAgents || 0;
                imagesProcessed = stats.imagesProcessed || 0;
                totalLeads = stats.totalLeads || 0;
                hoursSaved = stats.hoursSaved || 0;
                updateStats();
            }
            await loadUserAutomations();
        } catch (error) {
            console.debug('Live update failed, will retry');
        }
    }, 30000);
}

// ===== LOAD CONNECTED ACCOUNTS =====
async function loadConnectedAccounts() {
    const grid = document.getElementById('accountsGrid');
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/accounts`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        
        if (response.ok) {
            const accounts = await response.json();
            connectedAccounts = accounts;
            
            if (accounts.length === 0) {
                grid.innerHTML = '<div style="padding: 40px; text-align: center; width: 100%; color: var(--text-muted);"><i class="fas fa-plug fa-3x" style="margin-bottom: 15px; opacity: 0.5;"></i><h3>No accounts connected</h3><p>Connect your first platform to start automating</p><button class="btn-primary" onclick="showConnectModal()" style="margin-top: 15px;"><i class="fas fa-plus"></i> Connect Account</button></div>';
                return;
            }
            
            grid.innerHTML = accounts.map(account => {
                const platform = platforms.find(p => p.id === account.platform) || { 
                    icon: 'fas fa-plug', 
                    color: '#64748b',
                    name: account.platform || 'Unknown',
                    type: 'api-wrapper',
                    governance: 'basic'
                };
                
                let typeBadge = '';
                if (platform.type === 'saas') {
                    typeBadge = '<span class="platform-type-badge type-saas"><i class="fas fa-building"></i> Full SaaS</span>';
                } else if (platform.type === 'gateway') {
                    typeBadge = '<span class="platform-type-badge type-gateway"><i class="fas fa-cloud"></i> Gateway</span>';
                } else {
                    typeBadge = '<span class="platform-type-badge type-api-wrapper"><i class="fas fa-key"></i> API Wrapper</span>';
                }
                
                let accountInfo = account.account_info || {};
                if (typeof accountInfo === 'string') {
                    try {
                        accountInfo = JSON.parse(accountInfo);
                    } catch (e) {
                        accountInfo = {};
                    }
                }
                
                const accountName = account.account_name || account.name || platform.name;
                const lastSync = account.last_sync ? new Date(account.last_sync).toLocaleString() : 'Never';
                
                const govFeatures = platform.governance === 'full' ? 
                    '<div class="governance-tags"><span class="gov-tag"><i class="fas fa-check-circle"></i> Model Policies</span><span class="gov-tag"><i class="fas fa-check-circle"></i> Budget Controls</span><span class="gov-tag"><i class="fas fa-check-circle"></i> Audit Logs</span></div>' :
                    platform.governance === 'high' ?
                    '<div class="governance-tags"><span class="gov-tag"><i class="fas fa-check-circle"></i> Unified Billing</span><span class="gov-tag"><i class="fas fa-check-circle"></i> Rate Limiting</span></div>' :
                    '<div class="governance-tags"><span class="gov-tag"><i class="fas fa-exclamation-triangle"></i> Basic Governance</span></div>';
                
                return `
                    <div class="account-card">
                        <div class="account-row">
                            <div class="account-info">
                                <div class="account-avatar" style="background: ${platform.color};">
                                    <i class="${platform.icon}"></i>
                                </div>
                                <div class="account-details">
                                    <h4>${accountName} ${typeBadge}</h4>
                                    <p>${platform.name}</p>
                                    ${govFeatures}
                                </div>
                            </div>
                            <div class="account-status">
                                <span class="status-badge" style="background: ${account.status === 'active' ? 'var(--success)' : 'var(--warning)'};"></span>
                                <button class="icon-btn" onclick="configureAccount('${account.platform}')">
                                    <i class="fas fa-cog"></i>
                                </button>
                            </div>
                        </div>
                        <small style="color: var(--text-muted); font-size: 0.7rem; margin-top: 8px; display: block;">
                            Last sync: ${lastSync} | 
                            ${platform.multiAgent ? '<i class="fas fa-check-circle" style="color: var(--success);"></i> Multi-agent support' : '<i class="fas fa-times-circle" style="color: var(--text-muted);"></i> Single agent'}
                        </small>
                    </div>
                `;
            }).join('');
        } else {
            const errorText = await response.text();
            console.error('Error response:', errorText);
            throw new Error(`HTTP ${response.status}: ${errorText}`);
        }
    } catch (error) {
        console.error('Error loading accounts:', error);
        grid.innerHTML = '<div style="padding: 40px; text-align: center; width: 100%; color: var(--text-muted);"><i class="fas fa-exclamation-triangle fa-3x" style="margin-bottom: 15px; opacity: 0.5;"></i><h3>Failed to load accounts</h3><p>Please try again later</p><button class="btn-primary" onclick="loadConnectedAccounts()" style="margin-top: 10px;">Retry</button></div>';
    }
}

// ===== LOAD PLATFORM OPTIONS =====
function loadPlatformOptions() {
    const optionsDiv = document.getElementById('platformOptions');
    if (!optionsDiv) return;
    
    const sortedPlatforms = [...platforms].sort((a, b) => {
        const order = { 'saas': 1, 'gateway': 2, 'api-wrapper': 3 };
        return (order[a.type] || 4) - (order[b.type] || 4);
    });
    
    optionsDiv.innerHTML = sortedPlatforms.map(p => {
        let typeIndicator = '';
        if (p.type === 'saas') typeIndicator = '<span class="platform-type-indicator type-saas"><i class="fas fa-building"></i></span>';
        else if (p.type === 'gateway') typeIndicator = '<span class="platform-type-indicator type-gateway"><i class="fas fa-cloud"></i></span>';
        else typeIndicator = '<span class="platform-type-indicator type-api-wrapper"><i class="fas fa-key"></i></span>';
        
        return `
            <div class="platform-option" onclick="selectPlatform('${p.id}')" data-platform="${p.id}">
                ${typeIndicator}
                <i class="${p.icon}" style="color: ${p.color};"></i>
                <p>${p.name}</p>
                <small style="font-size: 0.6rem; color: var(--text-muted);">${p.type === 'saas' ? 'Full SaaS' : p.type === 'gateway' ? 'Gateway' : 'API'}</small>
            </div>
        `;
    }).join('');
}

// ===== TOGGLE CONNECTION METHOD =====
function toggleConnectionMethod() {
    const method = document.getElementById('connectionMethod').value;
    if (method === 'gateway') {
        document.getElementById('gatewayFields').style.display = 'block';
        document.getElementById('directFields').style.display = 'none';
    } else {
        document.getElementById('gatewayFields').style.display = 'none';
        document.getElementById('directFields').style.display = 'block';
    }
}

// ===== SEARCH PLATFORMS =====
function searchPlatforms() {
    const searchTerm = document.getElementById('platformSearch').value.toLowerCase().trim();
    const accountCards = document.querySelectorAll('.account-card');
    const featureCards = document.querySelectorAll('.feature-card');
    
    if (searchTerm === '') {
        accountCards.forEach(card => card.style.display = 'flex');
        featureCards.forEach(card => card.style.display = 'block');
        return;
    }
    
    accountCards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(searchTerm) ? 'flex' : 'none';
    });
    
    featureCards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(searchTerm) ? 'block' : 'none';
    });
    
    showToast(`🔍 Searching for "${searchTerm}"`, 'info');
}

// ===== FILTER FEATURES =====
function filterFeatures(category) {
    document.querySelectorAll('.feature-tab').forEach(tab => tab.classList.remove('active'));
    event.target.classList.add('active');
    
    const cards = document.querySelectorAll('.feature-card');
    cards.forEach(card => {
        card.style.display = (category === 'all' || card.dataset.category === category) ? 'block' : 'none';
    });
}

// ===== LOAD ACTIVITY LOG =====
async function loadActivityLog() {
    const log = document.getElementById('activityLog');
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/activity`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (!response.ok) throw new Error('Failed to load activity');
        
        const activities = await response.json();
        recentActivity = activities || [];
        
        if (recentActivity.length === 0) {
            log.innerHTML = `
                <div class="log-header">
                    <span class="chart-title">Recent Activity</span>
                    <span style="color: var(--text-muted); font-size: 0.75rem;" id="liveIndicator">Live</span>
                </div>
                <div style="padding: 30px; text-align: center; color: var(--text-muted);">
                    <i class="fas fa-history fa-2x" style="margin-bottom: 10px; opacity: 0.5;"></i>
                    <p>No recent activity</p>
                </div>
            `;
            return;
        }
        
        log.innerHTML = `
            <div class="log-header">
                <span class="chart-title">Recent Activity</span>
                <span style="color: var(--text-muted); font-size: 0.75rem;" id="liveIndicator">Live</span>
            </div>
            ${recentActivity.map(a => {
                let icon = 'fa-info-circle';
                if (a.type === 'budget') icon = 'fa-dollar-sign';
                else if (a.type === 'alert') icon = 'fa-exclamation-triangle';
                else if (a.type === 'approval') icon = 'fa-check-circle';
                else if (a.type === 'content') icon = 'fa-pen-fancy';
                else if (a.type === 'social') icon = 'fa-share-alt';
                else if (a.type === 'video') icon = 'fa-video';
                else if (a.type === 'automation') icon = 'fa-robot';
                
                return `
                <div class="log-entry">
                    <div class="log-icon"><i class="fas ${icon}"></i></div>
                    <div class="log-content">
                        <div class="log-title">${a.title || a.message || 'Activity'}</div>
                        <div class="log-time">${a.time || a.created_at || 'Just now'}</div>
                    </div>
                </div>
            `}).join('')}
        `;
    } catch (error) {
        console.error('Error loading activity:', error);
        log.innerHTML = `
            <div class="log-header">
                <span class="chart-title">Recent Activity</span>
                <span style="color: var(--text-muted); font-size: 0.75rem;" id="liveIndicator">Live</span>
            </div>
            <div style="padding: 30px; text-align: center; color: var(--text-muted);">
                <i class="fas fa-exclamation-circle fa-2x" style="margin-bottom: 10px; opacity: 0.5;"></i>
                <p>Unable to load activity</p>
                <button class="btn-primary" onclick="loadActivityLog()" style="margin-top: 10px; padding: 8px 16px; font-size: 0.8rem;">Retry</button>
            </div>
        `;
    }
}

// ===== MODAL FUNCTIONS =====
function showConnectModal() {
    document.getElementById('connectModal').classList.add('active');
    toggleConnectionMethod();
}

function closeModal() {
    document.getElementById('connectModal').classList.remove('active');
    selectedPlatform = null;
    document.querySelectorAll('.platform-option').forEach(opt => opt.classList.remove('selected'));
    document.getElementById('accountName').value = '';
    document.getElementById('cfAccountId').value = '';
    document.getElementById('gatewayName').value = '';
    document.getElementById('cfToken').value = '';
    document.getElementById('apiKey').value = '';
    document.getElementById('additionalFields').innerHTML = '';
    document.getElementById('additionalFields').style.display = 'none';
}

function selectPlatform(platformId) {
    document.querySelectorAll('.platform-option').forEach(opt => opt.classList.remove('selected'));
    event.target.closest('.platform-option').classList.add('selected');
    selectedPlatform = platformId;
    
    const platform = platforms.find(p => p.id === platformId);
    
    if (platform && (platform.type === 'saas' || platform.type === 'gateway')) {
        document.getElementById('connectionMethod').value = 'gateway';
        toggleConnectionMethod();
        showToast(`💡 ${platform.name} works best with Cloudflare Gateway for governance`, 'info');
    } else {
        document.getElementById('connectionMethod').value = 'direct';
        toggleConnectionMethod();
    }
}

// ===== SETTINGS & OBSERVABILITY PANELS =====
function openSettings() {
    document.getElementById('settingsPanel').classList.add('active');
    fetchRealGovernanceData();
}

function closeSettings() {
    document.getElementById('settingsPanel').classList.remove('active');
}

function openObservability() {
    document.getElementById('observabilityPanel').classList.add('active');
    fetchRealObservabilityData();
}

function closeObservability() {
    document.getElementById('observabilityPanel').classList.remove('active');
}

// ===== FETCH REAL GOVERNANCE DATA =====
async function fetchRealGovernanceData() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/governance`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        if (response.ok) {
            const data = await response.json();
            
            // Update GPT-4 policy
            const gpt4Select = document.querySelector('#gpt4-policy select');
            if (gpt4Select) {
                gpt4Select.innerHTML = data.gpt4.options.map(opt => 
                    `<option ${opt.selected ? 'selected' : ''}>${opt.name}</option>`
                ).join('');
            }
            
            // Update Claude policy
            const claudeSelect = document.querySelector('#claude-policy select');
            if (claudeSelect) {
                claudeSelect.innerHTML = data.claude.options.map(opt => 
                    `<option ${opt.selected ? 'selected' : ''}>${opt.name}</option>`
                ).join('');
            }
            
            // Update Gemini policy
            const geminiSelect = document.querySelector('#gemini-policy select');
            if (geminiSelect) {
                geminiSelect.innerHTML = data.gemini.options.map(opt => 
                    `<option ${opt.selected ? 'selected' : ''}>${opt.name}</option>`
                ).join('');
            }
            
            // Update budget
            const monthlyBudget = document.querySelector('#monthly-budget');
            if (monthlyBudget) {
                monthlyBudget.innerHTML = `
                    <div class="policy-row">
                        <span>Monthly Spend Cap</span>
                        <span>$${data.budgets.monthlyCap}</span>
                    </div>
                    <div class="cost-bar" style="margin: 8px 0;">
                        <div class="cost-fill" style="width: ${(data.budgets.used / data.budgets.monthlyCap * 100)}%;"></div>
                    </div>
                    <div class="policy-row">
                        <span>Used: $${data.budgets.used}</span>
                        <span>Remaining: $${data.budgets.monthlyCap - data.budgets.used}</span>
                    </div>
                `;
            }
            
            // Update compliance checkboxes
            document.getElementById('piiRedaction').checked = data.compliance.piiRedaction;
            document.getElementById('hipaaMode').checked = data.compliance.hipaaMode;
            document.getElementById('gdpr').checked = data.compliance.gdpr;
            
            // Update tool status
            document.getElementById('salesforce-status').textContent = data.tools.salesforce;
            document.getElementById('hubspot-status').textContent = data.tools.hubspot;
            document.getElementById('shopify-status').textContent = data.tools.shopify;
        }
    } catch (error) {
        console.error('Error fetching governance data:', error);
    }
}

// ===== FETCH REAL OBSERVABILITY DATA =====
async function fetchRealObservabilityData() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/observability`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (response.status === 401) { 
            localStorage.removeItem('token'); 
            window.location.href = 'login.html'; 
            return; 
        } 
        if (response.ok) {
            const data = await response.json();
            
            // Update alerts
            const alertsContainer = document.getElementById('alerts-container');
            if (alertsContainer && data.alerts && data.alerts.length > 0) {
                alertsContainer.innerHTML = data.alerts.map(alert => `
                    <div class="alert-item ${alert.severity || 'warning'}">
                        <div class="alert-header">
                            <strong><i class="fas ${alert.severity === 'critical' ? 'fa-times-circle' : alert.severity === 'warning' ? 'fa-exclamation-triangle' : 'fa-info-circle'}"></i> ${alert.title}</strong>
                            <span>${new Date(alert.created_at).toLocaleTimeString()}</span>
                        </div>
                        <div>${alert.description}</div>
                    </div>
                `).join('');
            }
            
            // Update costs
            if (data.costs && data.costs.length > 0) {
                const costProviders = {
                    'OpenAI (GPT-4)': 'openai-cost',
                    'Anthropic (Claude)': 'anthropic-cost',
                    'Google (Gemini)': 'google-cost'
                };
                
                data.costs.forEach(cost => {
                    const elementId = costProviders[cost.provider];
                    if (elementId) {
                        const element = document.getElementById(elementId);
                        if (element) {
                            element.innerHTML = `
                                <div class="policy-row">
                                    <span>${cost.provider}</span>
                                    <span>$${cost.total}</span>
                                </div>
                                <div class="cost-bar">
                                    <div class="cost-fill" style="width: ${cost.percentage}%;"></div>
                                </div>
                            `;
                        }
                    }
                });
            }
            
            // Update agent performance
            if (data.performance && data.performance.length > 0) {
                const perfMap = {
                    'Inventory Agent': 'inventory-agent-perf',
                    'Lead Scoring Agent': 'leads-agent-perf',
                    'Cart Recovery Agent': 'cart-agent-perf'
                };
                
                data.performance.forEach(agent => {
                    const elementId = perfMap[agent.name];
                    if (elementId) {
                        const element = document.getElementById(elementId);
                        if (element) {
                            element.innerHTML = `
                                <div>${agent.name}</div>
                                <div style="display: flex; justify-content: space-between; font-size: 0.8rem;">
                                    <span>${agent.success_rate}% success</span>
                                    <span>${agent.avg_latency}ms avg</span>
                                </div>
                            `;
                        }
                    }
                });
            }
        }
    } catch (error) {
        console.error('Error fetching observability data:', error);
    }
}

function addAlertToObservability(alert) {
    const alertsContainer = document.getElementById('alerts-container');
    if (alertsContainer) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert-item ${alert.severity || 'warning'}`;
        alertDiv.innerHTML = `
            <div class="alert-header">
                <strong><i class="fas ${alert.severity === 'critical' ? 'fa-times-circle' : alert.severity === 'warning' ? 'fa-exclamation-triangle' : 'fa-info-circle'}"></i> ${alert.title}</strong>
                <span>Just now</span>
            </div>
            <div>${alert.description}</div>
        `;
        alertsContainer.prepend(alertDiv);
        if (alertsContainer.children.length > 5) {
            alertsContainer.lastChild.remove();
        }
    }
}

// ===== UPDATE MODEL POLICY =====
async function updateModelPolicy(model, policy) {
    try {
        const token = localStorage.getItem('token');
        await fetch(`${API_BASE}/powerhouse/governance/models/${model}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ policy })
        });
        showToast('✅ Model policy updated', 'success');
    } catch (error) {
        showToast('❌ Failed to update policy', 'error');
    }
}

// ===== TOAST NOTIFICATIONS =====
function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.style.background = type === 'success' ? '#059669' : type === 'info' ? '#2563eb' : '#dc2626';
    toast.style.color = 'white';
    toast.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'info' ? 'fa-info-circle' : 'fa-exclamation-circle'}"></i> ${message}`;
    document.body.appendChild(toast);
    setTimeout(() => {
        toast.style.animation = 'slideIn 0.3s reverse';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

// ===== ADD NOTIFICATION =====
function addNotification(title, message) {
    const list = document.getElementById('notificationList');
    const count = document.getElementById('notificationCount');
    
    if (!list) return;
    
    let notificationCount = parseInt(count?.textContent || '0');
    notificationCount++;
    if (count) count.textContent = notificationCount;
    
    const item = document.createElement('div');
    item.className = 'notification-item unread';
    item.innerHTML = `
        <div class="notification-title">
            <span>${title}</span>
            <span class="time">Just now</span>
        </div>
        <div class="notification-message">${message}</div>
    `;
    list.prepend(item);
    
    if (list.children.length > 10) {
        list.lastChild.remove();
    }
}

// ===== CONTENT CREATION FUNCTIONS =====
function showContentModal() {
    document.getElementById('contentModal').classList.add('active');
    switchContentTab('generate');
}

function closeContentModal() {
    document.getElementById('contentModal').classList.remove('active');
}

function switchContentTab(tab) {
    document.querySelectorAll('#contentModal .feature-tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    
    document.getElementById('contentGenerateTab').style.display = tab === 'generate' ? 'block' : 'none';
    document.getElementById('contentImagesTab').style.display = tab === 'images' ? 'block' : 'none';
    document.getElementById('contentVideoTab').style.display = tab === 'video' ? 'block' : 'none';
    document.getElementById('contentScheduleTab').style.display = tab === 'schedule' ? 'block' : 'none';
}

async function generateContent() {
    const contentType = document.getElementById('contentType').value;
    const topic = document.getElementById('contentTopic').value;
    const tone = document.getElementById('contentTone').value;
    const platforms = Array.from(document.getElementById('contentPlatforms').selectedOptions).map(o => o.value);
    const instructions = document.getElementById('contentInstructions').value;
    
    if (!topic) {
        showToast('Please enter a topic', 'error');
        return;
    }
    
    showToast('🎨 Generating content with AI...', 'info');
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/content/create`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
                content_type: contentType,
                topic: topic,
                tone: tone,
                platforms: platforms,
                instructions: instructions
            })
        });
        
        if (response.ok) {
            const data = await response.json();
            showToast('✅ Content generated successfully!', 'success');
            alert('Generated content:\n\n' + data.content);
            
            addActiveFeature({
                id: 'content_' + Date.now(),
                name: `Content: ${topic.substring(0, 20)}`
            });
        } else {
            showToast('❌ Failed to generate content', 'error');
        }
    } catch (error) {
        console.error('Content generation error:', error);
        showToast('❌ Failed to generate content', 'error');
    }
}

async function generateImage() {
    const prompt = document.getElementById('imagePrompt').value;
    const style = document.getElementById('imageStyle').value;
    const ratio = document.getElementById('imageRatio').value;
    
    if (!prompt) {
        showToast('Please enter an image prompt', 'error');
        return;
    }
    
    showToast('🎨 Generating image with AI...', 'info');
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/images/generate`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
                prompt: prompt,
                style: style,
                ratio: ratio
            })
        });
        
        if (response.ok) {
            const data = await response.json();
            document.getElementById('imagePreview').src = data.image_url;
            document.getElementById('imagePreview').style.display = 'block';
            showToast('✅ Image generated!', 'success');
        } else {
            showToast('❌ Failed to generate image', 'error');
        }
    } catch (error) {
        console.error('Image generation error:', error);
        showToast('❌ Failed to generate image', 'error');
    }
}

async function generateVideoScript() {
    const topic = document.getElementById('videoTopic').value;
    const length = document.getElementById('videoLength').value;
    const captions = document.getElementById('videoCaptions').value;
    
    if (!topic) {
        showToast('Please enter a video topic', 'error');
        return;
    }
    
    showToast('🎬 Generating video script...', 'info');
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/video/script`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
                topic: topic,
                length: length,
                captions: captions === 'yes'
            })
        });
        
        if (response.ok) {
            const data = await response.json();
            showToast('✅ Script generated!', 'success');
            alert('Video script:\n\n' + data.script);
        } else {
            showToast('❌ Failed to generate script', 'error');
        }
    } catch (error) {
        console.error('Script generation error:', error);
        showToast('❌ Failed to generate script', 'error');
    }
}

async function scheduleContent() {
    const content = document.getElementById('scheduleContent').value;
    const platforms = Array.from(document.getElementById('schedulePlatforms').selectedOptions).map(o => o.value);
    const scheduleTime = document.getElementById('scheduleTime').value;
    
    if (!content || !scheduleTime) {
        showToast('Please fill in all fields', 'error');
        return;
    }
    
    showToast('📅 Scheduling content...', 'info');
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE}/powerhouse/social/schedule`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
                content: content,
                platforms: platforms,
                schedule: scheduleTime
            })
        });
        
        if (response.ok) {
            showToast('✅ Content scheduled!', 'success');
            closeContentModal();
        } else {
            showToast('❌ Failed to schedule content', 'error');
        }
    } catch (error) {
        console.error('Scheduling error:', error);
        showToast('❌ Failed to schedule content', 'error');
    }
}

